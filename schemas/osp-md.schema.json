{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openserviceprotocol.org/schemas/osp-md.schema.json",
  "title": "OSP Discovery File (osp.md)",
  "description": "Schema for validating the structured content of an osp.md file. Note: osp.md files are Markdown, not JSON. This schema describes the expected structure for validation tools that parse the Markdown into a structured representation.",
  "type": "object",
  "required": ["name", "summary"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Company or organization name (H1 heading)"
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph description (blockquote after H1)",
      "maxLength": 500
    },
    "available_services": {
      "type": "array",
      "description": "List of services offered",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "manifest_url": {
            "type": "string",
            "description": "Relative or absolute URL to the service manifest YAML"
          },
          "description": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "not_available": {
      "type": "array",
      "description": "Explicit list of services not offered",
      "items": {
        "type": "string"
      }
    },
    "conditions": {
      "type": "object",
      "properties": {
        "minimum_order": {
          "type": "string"
        },
        "regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "response_time": {
          "type": "string"
        }
      }
    },
    "integration": {
      "type": "object",
      "required": ["osp_version"],
      "properties": {
        "osp_version": {
          "type": "string",
          "description": "OSP specification version",
          "enum": ["0.1"]
        },
        "contracting": {
          "type": "string",
          "enum": ["available", "not yet"]
        },
        "delivery_tracking": {
          "type": "string",
          "enum": ["available", "not yet"]
        },
        "settlement": {
          "type": "string",
          "enum": ["token", "invoice", "not yet"]
        },
        "mcp_endpoint": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
